#!/usr/bin/env bash

# Resolve real directory path of the script (resolving symlinks)
SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
if [ -f "${SCRIPT_DIR}/common.sh" ]; then
    source "${SCRIPT_DIR}/common.sh"
else
    echo "Error: common.sh helper file not found!"
    exit 1
fi

echo -e "\n${BLUE}${BOLD}=============================================================${NC}"
echo -e "${BLUE}${BOLD}             Hatchyu Pipeline Engine: Security               ${NC}"
echo -e "${BLUE}${BOLD}=============================================================${NC}\n"

log_info "Scanning package dependencies for security vulnerabilities..."

if [ ! -f composer.json ]; then
    log_error "No composer.json found in the current directory!"
    exit 1
fi

SECURITY_FAILED=0

# 1. Run local-php-security-checker if available and lock file exists
if command -v local-php-security-checker >/dev/null 2>&1; then
    if [ -f composer.lock ]; then
        log_info "Running local-php-security-checker..."
        if local-php-security-checker --path=composer.lock; then
            log_success "local-php-security-checker scan passed."
        else
            log_error "local-php-security-checker found security vulnerabilities!"
            SECURITY_FAILED=1
        fi
    else
        log_warning "composer.lock not found. Skipping local-php-security-checker."
    fi
else
    log_info "local-php-security-checker not found in PATH."
fi

echo ""

# 2. Run composer audit if composer is available
if command -v composer >/dev/null 2>&1; then
    log_info "Running 'composer audit'..."
    if composer audit --no-interaction; then
        log_success "composer audit scan passed."
    else
        log_error "composer audit found security vulnerabilities!"
        SECURITY_FAILED=1
    fi
else
    log_warning "Composer is not installed or not in PATH. Skipping 'composer audit'."
fi

# Exit with error if any security scan failed
if [ $SECURITY_FAILED -ne 0 ]; then
    log_error "Security audits failed! Please address the issues listed above."
    exit 1
fi

echo -e "\n${GREEN}${BOLD}✨ Security scans completed successfully!${NC}\n"
